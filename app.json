{
  "expo": {
    "name": "showcase-trading-app",
    "slug": "showcase-trading-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "showcasetradingapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.showcasetradingapp",
      "icon": {
        "light": "./assets/images/icon-dark.png",
        "dark": "./assets/images/icon-light.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-light.png",
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.showcasetradingapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon-dark.png",
          "backgroundColor": "#FFFFFF",
          "resizeMode": "contain",
          "dark": {
            "image": "./assets/images/icon-light.png",
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
